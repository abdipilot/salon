# Database
POSTGRES_DB=salon
POSTGRES_USER=salon_app
POSTGRES_PASSWORD=change_this_secure_password

# Redis
REDIS_PASSWORD=change_this_redis_password

# JWT
JWT_SECRET=change_this_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars

# MinIO (self-hosted S3)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_this_minio_password
MINIO_BUCKET=salon-uploads

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key

# App
APP_URL=https://salon.somict.com

# Super Admin (created on first boot)
SUPER_ADMIN_EMAIL=admin@salon.somict.com
SUPER_ADMIN_PASSWORD=Admin@1234
